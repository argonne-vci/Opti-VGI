# CitrineOS Docker Stack Configuration
# Copy to .env before running: cp example.env .env

# CitrineOS ports (exposed to host)
CITRINEOS_PORT=8080
OCPP16_PORT=8092

# Hasura GraphQL Engine port (exposed to host for operator UI)
HASURA_PORT=8090

# Operator dashboard port (built from source)
OPERATOR_UI_PORT=3000

# Simulator configuration
STATION_IDS=OPTIVGI-STATION-01,OPTIVGI-STATION-02,OPTIVGI-STATION-03,OPTIVGI-STATION-04,OPTIVGI-STATION-05,OPTIVGI-STATION-06
CONNECTORS_PER_STATION=2
METER_VALUES_INTERVAL=10
CITRINEOS_WS_URL=ws://citrineos:8092

# Simulator scenario file (empty = wait-for-trigger mode, no auto-sessions)
# Set to a path like "scenarios/default.json" to auto-schedule sessions
SCENARIO_FILE=scenarios/default.json

# Comma-separated idTags to seed in CitrineOS Authorizations table
SEED_ID_TAGS=OPTIVGI-01,OPTIVGI-02,OPTIVGI-03,OPTIVGI-04,OPTIVGI-05,OPTIVGI-06

# Site power limit (kW) -- used by Opti-VGI
SITE_POWER_LIMIT_KW=30

# Voltage (V) for W/A conversions
VOLTAGE=240

# Station groups for Opti-VGI scheduling
STATION_GROUPS=default

# CitrineOS API URL (internal Docker network)
CITRINEOS_API_URL=http://citrineos:8080

# Hasura GraphQL URL (internal Docker network)
HASURA_URL=http://graphql-engine:8080

# RabbitMQ AMQP URL
AMQP_URL=amqp://guest:guest@amqp-broker:5672

# Per-connector EV configuration (station=EVSE, connector=port in OCPP 1.6J)
# Each CONN_XX maps to the Nth station in STATION_IDS (CONN_01 -> station index 0, etc.)

# Connector 01 = OPTIVGI-STATION-01, connector 1
CONN_01_ENERGY_NEEDED_KWH=30
CONN_01_MAX_POWER_KW=7.2
CONN_01_MIN_POWER_KW=1.4
CONN_01_ARRIVAL_TIME=06:00
CONN_01_DEPARTURE_TIME=14:00

# Connector 02 = OPTIVGI-STATION-02, connector 1
CONN_02_ENERGY_NEEDED_KWH=25
CONN_02_MAX_POWER_KW=7.2
CONN_02_MIN_POWER_KW=1.4
CONN_02_ARRIVAL_TIME=07:00
CONN_02_DEPARTURE_TIME=15:00

# Connector 03 = OPTIVGI-STATION-03, connector 1
CONN_03_ENERGY_NEEDED_KWH=40
CONN_03_MAX_POWER_KW=7.2
CONN_03_MIN_POWER_KW=1.4
CONN_03_ARRIVAL_TIME=06:30
CONN_03_DEPARTURE_TIME=13:00

# Connector 04 = OPTIVGI-STATION-04, connector 1
CONN_04_ENERGY_NEEDED_KWH=20
CONN_04_MAX_POWER_KW=7.2
CONN_04_MIN_POWER_KW=1.4
CONN_04_ARRIVAL_TIME=08:00
CONN_04_DEPARTURE_TIME=16:00

# Connector 05 = OPTIVGI-STATION-05, connector 1
CONN_05_ENERGY_NEEDED_KWH=35
CONN_05_MAX_POWER_KW=7.2
CONN_05_MIN_POWER_KW=1.4
CONN_05_ARRIVAL_TIME=07:30
CONN_05_DEPARTURE_TIME=14:30

# Connector 06 = OPTIVGI-STATION-06, connector 1
CONN_06_ENERGY_NEEDED_KWH=28
CONN_06_MAX_POWER_KW=7.2
CONN_06_MIN_POWER_KW=1.4
CONN_06_ARRIVAL_TIME=09:00
CONN_06_DEPARTURE_TIME=17:00
